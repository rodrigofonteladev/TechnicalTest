<div class="container d-flex justify-content-center align-items-center">

    <div class="card shadow-sm border-0 text-center p-5" style="max-width: 500px; border-radius: 15px;">
        <div class="card-body">
            <div class="mb-4">
                <i class="bi bi-headset fs-0 text-primary" style="font-size: 4rem;"></i>
            </div>
            
            <h4 class="fw-bold mb-3">Cuenta bloqueada temporalmente</h4>
            
            <p class="text-muted">
                Has excedido el límite de intentos. Podrás intentar de nuevo en:
            </p>

            <div class="display-4 fw-bold text-primary mb-4" id="countdown">
                --:--
            </div>

            <p class="small text-secondary">
                Al finalizar el tiempo, serás redirigido automáticamente al inicio de sesión.
            </p>
        </div>
    </div>

</div>

@section Scripts {
    <script>
        let seconds = @(ViewBag.RemainingSeconds ?? 900);
        const display = document.querySelector('#countdown');

        function updateDisplay() {
            if (seconds < 0) {
                clearInterval(timer);
                window.location.href = '@Url.Action("Login", "Auth")';
                return;
            }

            let minutes = Math.floor(seconds / 60);
            let remSeconds = seconds % 60;

            display.textContent =
                (minutes < 10 ? "0" : "") + minutes + ":" +
                (remSeconds < 10 ? "0" : "") + remSeconds;
        }

        updateDisplay();

        const timer = setInterval(function () {
            seconds--;
            updateDisplay();
        }, 1000);
    </script>
}